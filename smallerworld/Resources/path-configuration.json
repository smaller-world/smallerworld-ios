{
  "settings": {},
  "rules": [
    {
      "patterns": ["^\/home$"],
      "properties": {
        "presentation": "replace_root"
      }
    },
    {
      "patterns": ["\/new$", "\/edit$", "^\/world_invitations\/.+$"],
      "properties": {
        "context": "modal",
        "pull_to_refresh_enabled": false
      }
    },
    {
      "patterns": ["^\/session\/new$"],
      "properties": {
        "context": "default",
        "presentation": "replace_root",
        "pull_to_refresh_enabled": true
      }
    },
    {
      "patterns": [
        "^\/worlds\/new$",
        "^\/worlds\/[\\w-]+\/edit$",
        "\/posts\/new",
        "^\/posts\/[\\w-]+\/edit$"
      ],
      "properties": {
        "modal_style": "full"
      }
    },
    {
      "patterns": ["^\/worlds\/[\\w-]+$"],
      "properties": {
        "interactive_content_pop_gesture_enabled": false
      }
    },
    {
      "patterns": ["^\/scan_qr_code$"],
      "properties": {
        "view_controller": "qr_code_scanner",
        "context": "modal"
      }
    }
  ]
}
