{
  "settings": {},
  "rules": [
    {
      "patterns": ["^\/home$"],
      "properties": {
        "presentation": "replace_root"
      }
    },
    {
      "patterns": [
        "\/new$",
        "\/edit$",
        "^\/world_key_grants\/.+$",
        "^\/world_cards\/[\\w-]+\/key_grant$",
        "\/settings$"
      ],
      "properties": {
        "context": "modal",
        "pull_to_refresh_enabled": false
      }
    },
    {
      "patterns": ["^\/session\/new$"],
      "properties": {
        "context": "default",
        "presentation": "replace_root",
        "pull_to_refresh_enabled": true
      }
    },
    {
      "patterns": ["^\/worlds\/new$", "^\/worlds\/[\\w-]+\/edit$"],
      "properties": {
        "modal_style": "full"
      }
    },
    {
      "patterns": ["\/posts\/new", "^\/posts\/[\\w-]+\/edit$"],
      "properties": {
        "modal_dismiss_gesture_enabled": false
      }
    },
    {
      "patterns": ["^\/worlds\/[\\w-]+$"],
      "properties": {
        "interactive_content_pop_gesture_enabled": false
      }
    },
    {
      "patterns": ["^\/scan_qr_code$"],
      "properties": {
        "view_controller": "qr_code_scanner",
        "context": "modal"
      }
    },
    {
      "patterns": [
        "^\/worlds$",
        "^\/world_key_grants$",
        "^\/world_cards$",
        "^\/world_cards\/[\\w-]+$"
      ],
      "properties": {
        "unroutable": true
      }
    }
  ]
}
